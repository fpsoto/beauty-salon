<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.ServiceFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:catalog="clr-namespace:BeautySalon.Application.Features.Catalog;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:ServiceFormViewModel"
    Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource Space16}" Spacing="{StaticResource Space12}">
            <Label Text="{x:Static strings:AppResources.Name}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding Name}" />
            </Border>

            <Label Text="{x:Static strings:AppResources.CategoryLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Picker ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}">
                    <Picker.ItemDisplayBinding>
                        <Binding Path="Name" x:DataType="catalog:ServiceCategoryDto" />
                    </Picker.ItemDisplayBinding>
                </Picker>
            </Border>

            <Label Text="{x:Static strings:AppResources.SuggestedPriceLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding SuggestedPrice}" Keyboard="Numeric" />
            </Border>

            <Label Text="{x:Static strings:AppResources.DurationMinutesLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding DurationMinutes}" Keyboard="Numeric" />
            </Border>

            <Label Text="{x:Static strings:AppResources.ColorOptionalLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding ColorHex}" Placeholder="#512BD4" />
            </Border>

            <Label Text="{x:Static strings:AppResources.DescriptionLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}" HeightRequest="80" Padding="{StaticResource Space16}">
                <Editor Text="{Binding Description}" HeightRequest="80" />
            </Border>

            <HorizontalStackLayout Spacing="{StaticResource Space8}">
                <CheckBox IsChecked="{Binding IsActive}" />
                <Label Text="{x:Static strings:AppResources.Active}" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <Button Text="{x:Static strings:AppResources.Save}" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
