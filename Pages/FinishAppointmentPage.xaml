<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.FinishAppointmentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:payments="clr-namespace:BeautySalon.Application.Features.Payments;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:FinishAppointmentViewModel"
    Title="{x:Static strings:AppResources.FinishAppointmentTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource Space16}" Spacing="{StaticResource Space12}">
            <Label Text="{x:Static strings:AppResources.ChargedPriceLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding ChargedPrice}" Keyboard="Numeric" Placeholder="0" VerticalOptions="Center" />
            </Border>

            <Label Text="{x:Static strings:AppResources.DiscountLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding Discount}" Keyboard="Numeric" Placeholder="0" VerticalOptions="Center" />
            </Border>

            <Label Text="{x:Static strings:AppResources.TipLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Text="{Binding Tip}" Keyboard="Numeric" Placeholder="0" VerticalOptions="Center" />
            </Border>

            <Label Text="{x:Static strings:AppResources.PaymentMethodLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Picker ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}" VerticalOptions="Center">
                    <Picker.ItemDisplayBinding>
                        <Binding Path="Name" x:DataType="payments:PaymentMethodDto" />
                    </Picker.ItemDisplayBinding>
                </Picker>
            </Border>

            <Label Text="{x:Static strings:AppResources.Notes}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}" Padding="16" HeightRequest="-1">
                <Editor Text="{Binding Notes}" HeightRequest="80" Placeholder="{x:Static strings:AppResources.Optional}" />
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <Button Text="{x:Static strings:AppResources.FinishAction}" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
