<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.FinishAppointmentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:payments="clr-namespace:BeautySalon.Application.Features.Payments;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:FinishAppointmentViewModel"
    Title="{x:Static strings:AppResources.FinishAppointmentTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">
            <Label Text="{x:Static strings:AppResources.ChargedPriceLabel}" FontAttributes="Bold" />
            <Entry Text="{Binding ChargedPrice}" Keyboard="Numeric" Placeholder="0" />

            <Label Text="{x:Static strings:AppResources.DiscountLabel}" FontAttributes="Bold" />
            <Entry Text="{Binding Discount}" Keyboard="Numeric" Placeholder="0" />

            <Label Text="{x:Static strings:AppResources.TipLabel}" FontAttributes="Bold" />
            <Entry Text="{Binding Tip}" Keyboard="Numeric" Placeholder="0" />

            <Label Text="{x:Static strings:AppResources.PaymentMethodLabel}" FontAttributes="Bold" />
            <Picker ItemsSource="{Binding PaymentMethods}" SelectedItem="{Binding SelectedPaymentMethod}">
                <Picker.ItemDisplayBinding>
                    <Binding Path="Name" x:DataType="payments:PaymentMethodDto" />
                </Picker.ItemDisplayBinding>
            </Picker>

            <Label Text="{x:Static strings:AppResources.Notes}" FontAttributes="Bold" />
            <Editor Text="{Binding Notes}" HeightRequest="80" Placeholder="{x:Static strings:AppResources.Optional}" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <Button Text="{x:Static strings:AppResources.FinishAction}" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
