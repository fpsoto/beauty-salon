<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.HelpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="clr-namespace:CommunityToolkit.Maui.Views;assembly=CommunityToolkit.Maui"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    Title="{x:Static strings:AppResources.HelpTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource Space16}" Spacing="{StaticResource Space12}">

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionAgendaTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionAgendaBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionClientsTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionClientsBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionCatalogTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionCatalogBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionPaymentsTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionPaymentsBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionReportsTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionReportsBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionSettingsTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionSettingsBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0">
                <toolkit:Expander>
                    <toolkit:Expander.Header>
                        <Label Text="{x:Static strings:AppResources.HelpSectionFaqTitle}" Style="{StaticResource H3}" Padding="{StaticResource Space16}" />
                    </toolkit:Expander.Header>
                    <Label Text="{x:Static strings:AppResources.HelpSectionFaqBody}" Style="{StaticResource BodySmall}" Padding="16,0,16,16" />
                </toolkit:Expander>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
