<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.AppointmentFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:clients="clr-namespace:BeautySalon.Application.Features.Clients;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:AppointmentFormViewModel"
    Title="{x:Static strings:AppResources.NewAppointmentTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="{StaticResource Space16}" Spacing="{StaticResource Space12}">

            <Label Text="{x:Static strings:AppResources.ClientLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <Entry Placeholder="{x:Static strings:AppResources.SearchClientPlaceholder}" Text="{Binding ClientSearchTerm}" TextChanged="OnClientSearchTextChanged" VerticalOptions="Center" />
            </Border>

            <Label
                Text="{Binding SelectedClient.Rut, StringFormat={x:Static strings:AppResources.SelectedClientFormat}}"
                IsVisible="{Binding SelectedClient, Converter={StaticResource IsNotNullConverter}}"
                Style="{StaticResource Caption}" />
            <Button
                Text="{x:Static strings:AppResources.ClearSelection}"
                Command="{Binding ClearSelectedClientCommand}"
                IsVisible="{Binding SelectedClient, Converter={StaticResource IsNotNullConverter}}"
                Style="{StaticResource SecondaryButton}"
                HorizontalOptions="Start" />

            <CollectionView
                ItemsSource="{Binding ClientResults}"
                SelectionMode="Single"
                SelectionChanged="OnClientSelected"
                HeightRequest="150"
                IsVisible="{Binding ClientResults.Count, Converter={StaticResource CountToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="clients:ClientDto">
                        <Grid Padding="{StaticResource Space8}">
                            <Label>
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} {1} · {2}">
                                        <Binding Path="Name" />
                                        <Binding Path="LastName" />
                                        <Binding Path="Phone" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" />

            <Label Text="{x:Static strings:AppResources.ServicesLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource Card}" Padding="0" HeightRequest="220">
                <CollectionView ItemsSource="{Binding Services}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:SelectableService">
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="{StaticResource Space12}" ColumnSpacing="{StaticResource Space8}">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" CheckedChanged="OnServiceCheckedChanged" />
                                <Label Grid.Column="1" Text="{Binding Service.Name}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding Service.DurationMinutes, StringFormat='{0} min'}" VerticalOptions="Center" Style="{StaticResource Caption}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <Label Style="{StaticResource H3}">
                <Label.Text>
                    <MultiBinding StringFormat="{x:Static strings:AppResources.AppointmentTotalFormat}">
                        <Binding Path="TotalPrice" />
                        <Binding Path="TotalDurationMinutes" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <BoxView HeightRequest="1" />

            <Label Text="{x:Static strings:AppResources.DateAndTimeLabel}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}">
                <DatePicker Date="{Binding AppointmentDate}" VerticalOptions="Center" />
            </Border>
            <Border Style="{StaticResource InputContainer}">
                <TimePicker Time="{Binding AppointmentTime}" Format="HH:mm" VerticalOptions="Center" />
            </Border>

            <Label Text="{x:Static strings:AppResources.Notes}" Style="{StaticResource FieldCaption}" />
            <Border Style="{StaticResource InputContainer}" Padding="16" HeightRequest="-1">
                <Editor Text="{Binding Notes}" HeightRequest="80" Placeholder="{x:Static strings:AppResources.Optional}" />
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <Button Text="{x:Static strings:AppResources.SaveAppointment}" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
