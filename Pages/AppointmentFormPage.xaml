<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.AppointmentFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:clients="clr-namespace:BeautySalon.Application.Features.Clients;assembly=BeautySalon.Application"
    x:DataType="viewModels:AppointmentFormViewModel"
    Title="Nueva cita">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Cliente" FontAttributes="Bold" />
            <Entry Placeholder="Buscar cliente por nombre, teléfono o RUT" Text="{Binding ClientSearchTerm}" TextChanged="OnClientSearchTextChanged" />

            <Label Text="{Binding SelectedClient.Rut, StringFormat='Seleccionado: RUT {0}'}" IsVisible="{Binding SelectedClient, Converter={StaticResource IsNotNullConverter}}" TextColor="{StaticResource Gray500}" FontSize="12" />
            <Button Text="Quitar selección" Command="{Binding ClearSelectedClientCommand}" IsVisible="{Binding SelectedClient, Converter={StaticResource IsNotNullConverter}}" FontSize="12" Padding="8,4" HorizontalOptions="Start" />

            <CollectionView
                ItemsSource="{Binding ClientResults}"
                SelectionMode="Single"
                SelectionChanged="OnClientSelected"
                HeightRequest="150"
                IsVisible="{Binding ClientResults.Count, Converter={StaticResource CountToBoolConverter}}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="clients:ClientDto">
                        <Grid Padding="8,6">
                            <Label>
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} {1} · {2}">
                                        <Binding Path="Name" />
                                        <Binding Path="LastName" />
                                        <Binding Path="Phone" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}" />

            <Label Text="Servicios" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Services}" HeightRequest="220">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:SelectableService">
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="4,6" ColumnSpacing="8">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" CheckedChanged="OnServiceCheckedChanged" />
                            <Label Grid.Column="1" Text="{Binding Service.Name}" VerticalOptions="Center" />
                            <Label Grid.Column="2" Text="{Binding Service.DurationMinutes, StringFormat='{0} min'}" VerticalOptions="Center" FontSize="12" TextColor="{StaticResource Gray500}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label FontAttributes="Bold">
                <Label.Text>
                    <MultiBinding StringFormat="Total: ${0} · {1} min">
                        <Binding Path="TotalPrice" />
                        <Binding Path="TotalDurationMinutes" />
                    </MultiBinding>
                </Label.Text>
            </Label>

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}" />

            <Label Text="Fecha y hora" FontAttributes="Bold" />
            <DatePicker Date="{Binding AppointmentDate}" />
            <TimePicker Time="{Binding AppointmentTime}" Format="HH:mm" />

            <Label Text="Observaciones" FontAttributes="Bold" />
            <Editor Text="{Binding Notes}" HeightRequest="80" Placeholder="Opcional" />

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <Button Text="Guardar cita" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
