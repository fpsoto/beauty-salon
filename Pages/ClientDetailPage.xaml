<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.ClientDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:clients="clr-namespace:BeautySalon.Application.Features.Clients;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:ClientDetailViewModel"
    Title="{x:Static strings:AppResources.ClientDetailTitle}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static strings:AppResources.Edit}" Clicked="OnEditClicked" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">

            <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                <Border StrokeShape="RoundRectangle 40" HeightRequest="80" WidthRequest="80" Padding="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PrimarySoft}, Dark={StaticResource PrimarySoftDark}}"
                        Stroke="Transparent">
                    <Label Text="{Binding Initials}" FontFamily="InterSemibold" FontSize="28"
                           TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                </Border>

                <Label Style="{StaticResource H2}" HorizontalTextAlignment="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0} {1}">
                            <Binding Path="Detail.Client.Name" />
                            <Binding Path="Detail.Client.LastName" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label Text="{Binding Detail.Client.Rut, StringFormat={x:Static strings:AppResources.RutFormat}}" Style="{StaticResource BodySmall}" HorizontalTextAlignment="Center" />
                <Label Text="{Binding Detail.Client.Phone}" Style="{StaticResource BodySmall}" HorizontalTextAlignment="Center" />

                <Button Text="{x:Static strings:AppResources.Favorite}" Command="{Binding ToggleFavoriteCommand}" Style="{StaticResource TertiaryButton}" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" />

            <Grid ColumnDefinitions="*,*,*" RowSpacing="4">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{Binding Detail.VisitCount}" Style="{StaticResource H2}" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.Visits}" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="{Binding Detail.TotalSpent, StringFormat='${0}'}" Style="{StaticResource H2}" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.TotalSpent}" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <Label Text="{Binding Detail.LastVisit, StringFormat='{0:dd/MM/yyyy}'}" Style="{StaticResource H3}" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.LastVisit}" Style="{StaticResource Caption}" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

            <BoxView HeightRequest="1" />

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                <Button Grid.Column="0" Text="{x:Static strings:AppResources.Call}" Command="{Binding CallCommand}" Style="{StaticResource SecondaryButton}" FontSize="14" />
                <Button Grid.Column="1" Text="{x:Static strings:AppResources.WhatsAppLabel}" Command="{Binding SendWhatsAppCommand}" Style="{StaticResource SecondaryButton}" FontSize="14" />
                <Button Grid.Column="2" Text="{x:Static strings:AppResources.Email}" Command="{Binding SendEmailCommand}" Style="{StaticResource SecondaryButton}" FontSize="14" />
            </Grid>

            <BoxView HeightRequest="1" />

            <Label Text="{x:Static strings:AppResources.AppointmentHistory}" Style="{StaticResource H3}" />
            <CollectionView ItemsSource="{Binding Detail.Appointments}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="clients:AppointmentSummaryDto">
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Label Grid.Column="0" Text="{Binding Date, StringFormat='{0:dd/MM/yy}'}" Style="{StaticResource Caption}" WidthRequest="70" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding ServicesSummary}" Style="{StaticResource BodySmall}" VerticalOptions="Center" />
                                <Label Grid.Column="2" Text="{Binding ChargedPrice, StringFormat='${0}'}" Style="{StaticResource FieldCaption}" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
