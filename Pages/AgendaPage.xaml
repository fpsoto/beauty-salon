<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.AgendaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:AgendaViewModel"
    Title="{x:Static strings:AppResources.AgendaTitle}">

    <Grid RowDefinitions="Auto, *" RowSpacing="0">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="16,12" ColumnSpacing="8">
            <Button Grid.Column="0" Text="&#8592;" Command="{Binding GoToPreviousWeekCommand}" Style="{StaticResource TertiaryButton}" WidthRequest="44" HeightRequest="44" MinimumHeightRequest="44" HorizontalOptions="Center" />
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Label Style="{StaticResource H3}" HorizontalTextAlignment="Center">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0:dd/MM} - {1:dd/MM}">
                            <Binding Path="WeekStart" />
                            <Binding Path="WeekEnd" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Button Text="{x:Static strings:AppResources.Today}" Command="{Binding GoToTodayCommand}" Style="{StaticResource TertiaryButton}" FontSize="13" Padding="8,2" MinimumHeightRequest="28" HeightRequest="28" />
            </VerticalStackLayout>
            <Button Grid.Column="2" Text="&#8594;" Command="{Binding GoToNextWeekCommand}" Style="{StaticResource TertiaryButton}" WidthRequest="44" HeightRequest="44" MinimumHeightRequest="44" HorizontalOptions="Center" />
        </Grid>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadWeekCommand}">
            <CollectionView
                x:Name="AgendaCollectionView"
                ItemsSource="{Binding DayGroups}"
                IsGrouped="True"
                SelectionMode="Single"
                SelectionChanged="OnEntrySelected"
                Margin="0,0,0,80">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="viewModels:DayAgendaGroup">
                        <Label
                            Text="{Binding DayLabel}"
                            Style="{StaticResource FieldCaption}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Background}, Dark={StaticResource BackgroundDark}}"
                            Padding="16,10" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:AgendaEntry">
                        <Border Style="{StaticResource Card}" Margin="16,6" Padding="0">
                            <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                                <BoxView Grid.Column="0" Color="{Binding AccentColor}" />
                                <VerticalStackLayout Grid.Column="1" Spacing="4" Padding="12,12,16,12">
                                    <Label Text="{Binding TimeRangeLabel}" Style="{StaticResource Caption}" />
                                    <Label Text="{Binding Title}" Style="{StaticResource H3}" />
                                    <Label
                                        Text="{Binding Subtitle}"
                                        Style="{StaticResource BodySmall}"
                                        IsVisible="{Binding Subtitle, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />
                                    <Border
                                        Style="{StaticResource Badge}"
                                        BackgroundColor="{Binding BadgeBackgroundColor}"
                                        HorizontalOptions="Start"
                                        IsVisible="{Binding IsBlock, Converter={StaticResource InvertedBoolConverter}}">
                                        <Label Text="{Binding StatusLabel}" TextColor="{Binding BadgeTextColor}" FontSize="11" FontFamily="InterSemibold" VerticalOptions="Center" />
                                    </Border>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button
            Grid.Row="1"
            Text="+"
            Style="{StaticResource Fab}"
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,20,20"
            Clicked="OnCreateAppointmentClicked" />
    </Grid>
</ContentPage>
