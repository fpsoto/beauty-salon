<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.AgendaPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:AgendaViewModel"
    Title="{x:Static strings:AppResources.AgendaTitle}">

    <Grid RowDefinitions="Auto, *">
        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Padding="12,8" ColumnSpacing="8">
            <Button Grid.Column="0" Text="&#8592;" Command="{Binding GoToPreviousWeekCommand}" WidthRequest="48" />
            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                <Label HorizontalTextAlignment="Center" FontAttributes="Bold">
                    <Label.Text>
                        <MultiBinding StringFormat="{}{0:dd/MM} - {1:dd/MM}">
                            <Binding Path="WeekStart" />
                            <Binding Path="WeekEnd" />
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Button Text="{x:Static strings:AppResources.Today}" Command="{Binding GoToTodayCommand}" Padding="10,2" FontSize="12" />
            </VerticalStackLayout>
            <Button Grid.Column="2" Text="&#8594;" Command="{Binding GoToNextWeekCommand}" WidthRequest="48" />
        </Grid>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadWeekCommand}">
            <CollectionView
                x:Name="AgendaCollectionView"
                ItemsSource="{Binding DayGroups}"
                IsGrouped="True"
                SelectionMode="Single"
                SelectionChanged="OnEntrySelected"
                Margin="0,0,0,80">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="viewModels:DayAgendaGroup">
                        <Label
                            Text="{Binding DayLabel}"
                            FontAttributes="Bold"
                            FontSize="16"
                            BackgroundColor="{StaticResource Gray100}"
                            Padding="12,6" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:AgendaEntry">
                        <Grid ColumnDefinitions="6,*" Padding="12,8" ColumnSpacing="10">
                            <BoxView Grid.Column="0" Color="{Binding AccentColor}" WidthRequest="6" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="{Binding TimeRangeLabel}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label
                                    Text="{Binding Subtitle}"
                                    FontSize="13"
                                    TextColor="{StaticResource Gray500}"
                                    IsVisible="{Binding Subtitle, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />
                                <Label
                                    Text="{Binding StatusLabel}"
                                    FontSize="12"
                                    IsVisible="{Binding IsBlock, Converter={StaticResource InvertedBoolConverter}}" />
                            </VerticalStackLayout>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Button
            Grid.Row="1"
            Text="+"
            FontSize="28"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            VerticalOptions="End"
            HorizontalOptions="End"
            Margin="0,0,20,20"
            Clicked="OnCreateAppointmentClicked" />
    </Grid>
</ContentPage>
