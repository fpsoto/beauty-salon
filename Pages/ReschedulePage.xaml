<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.ReschedulePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    x:DataType="viewModels:RescheduleViewModel"
    Title="Reagendar cita">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="Nueva fecha" FontAttributes="Bold" />
        <DatePicker Date="{Binding NewDate}" />

        <Label Text="Nueva hora" FontAttributes="Bold" />
        <TimePicker Time="{Binding NewTime}" Format="HH:mm" />

        <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

        <Button Text="Reagendar" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
