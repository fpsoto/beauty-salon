<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.ReschedulePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:RescheduleViewModel"
    Title="{x:Static strings:AppResources.RescheduleTitle}">

    <VerticalStackLayout Padding="{StaticResource Space16}" Spacing="{StaticResource Space12}">
        <Label Text="{x:Static strings:AppResources.NewDateLabel}" Style="{StaticResource FieldCaption}" />
        <Border Style="{StaticResource InputContainer}">
            <DatePicker Date="{Binding NewDate}" VerticalOptions="Center" />
        </Border>

        <Label Text="{x:Static strings:AppResources.NewTimeLabel}" Style="{StaticResource FieldCaption}" />
        <Border Style="{StaticResource InputContainer}">
            <TimePicker Time="{Binding NewTime}" Format="HH:mm" VerticalOptions="Center" />
        </Border>

        <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

        <Button Text="{x:Static strings:AppResources.RescheduleAction}" Command="{Binding SaveCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
