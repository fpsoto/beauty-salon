<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Beauty_Salon.Pages.ReportsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Beauty_Salon.ViewModels"
    xmlns:reports="clr-namespace:BeautySalon.Application.Features.Reports;assembly=BeautySalon.Application"
    xmlns:strings="clr-namespace:Beauty_Salon.Resources.Strings"
    x:DataType="viewModels:ReportsViewModel"
    Title="{x:Static strings:AppResources.ReportsTitle}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <HorizontalStackLayout Spacing="8">
                <Button Text="{x:Static strings:AppResources.Today}" Command="{Binding SetTodayCommand}" FontSize="12" Padding="10,4" />
                <Button Text="{x:Static strings:AppResources.Week}" Command="{Binding SetThisWeekCommand}" FontSize="12" Padding="10,4" />
                <Button Text="{x:Static strings:AppResources.Month}" Command="{Binding SetThisMonthCommand}" FontSize="12" Padding="10,4" />
                <Button Text="{x:Static strings:AppResources.Year}" Command="{Binding SetThisYearCommand}" FontSize="12" Padding="10,4" />
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{x:Static strings:AppResources.FromLabel}" FontSize="12" />
                    <DatePicker Date="{Binding FromDate}" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="{x:Static strings:AppResources.ToLabel}" FontSize="12" />
                    <DatePicker Date="{Binding ToDate}" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="{x:Static strings:AppResources.Apply}" Command="{Binding LoadCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource IsStringNotNullOrEmptyConverter}}" />

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="12">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                    <Label Text="{Binding Summary.TotalRevenue, StringFormat='${0}'}" FontAttributes="Bold" FontSize="20" />
                    <Label Text="{x:Static strings:AppResources.Revenue}" FontSize="12" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                    <Label Text="{Binding Summary.CompletedAppointmentsCount}" FontAttributes="Bold" FontSize="20" />
                    <Label Text="{x:Static strings:AppResources.CompletedAppointments}" FontSize="12" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                    <Label Text="{Binding Summary.NewClientsCount}" FontAttributes="Bold" FontSize="20" />
                    <Label Text="{x:Static strings:AppResources.NewClients}" FontSize="12" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                    <Label Text="{Binding Summary.InactiveClientsCount}" FontAttributes="Bold" FontSize="20" />
                    <Label Text="{x:Static strings:AppResources.InactiveClients}" FontSize="12" />
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="4">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="{Binding Summary.AverageRevenuePerAppointment, StringFormat='${0}'}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.AveragePerAppointment}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="{Binding Summary.CancelledCount}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.Cancellations}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <Label Text="{Binding Summary.NoShowCount}" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    <Label Text="{x:Static strings:AppResources.NoShowAction}" FontSize="11" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>

            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}" />

            <Label Text="{x:Static strings:AppResources.RevenueByPaymentMethod}" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Summary.RevenueByPaymentMethod}" HeightRequest="120">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="reports:RevenueByPaymentMethodDto">
                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <Label Grid.Column="0" Text="{Binding PaymentMethodName}" />
                            <Label Grid.Column="1" Text="{Binding Amount, StringFormat='${0}'}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static strings:AppResources.TopClients}" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Summary.TopClients}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="reports:TopClientDto">
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,4" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding ClientFullName}" />
                            <Label Grid.Column="1" Text="{Binding VisitCount, StringFormat={x:Static strings:AppResources.VisitCountFormat}}" FontSize="12" />
                            <Label Grid.Column="2" Text="{Binding TotalSpent, StringFormat='${0}'}" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static strings:AppResources.TopServices}" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Summary.TopServices}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="reports:TopServiceDto">
                        <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,4" ColumnSpacing="8">
                            <Label Grid.Column="0" Text="{Binding ServiceName}" />
                            <Label Grid.Column="1" Text="{Binding Count, StringFormat='x{0}'}" FontSize="12" />
                            <Label Grid.Column="2" Text="{Binding Revenue, StringFormat='${0}'}" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static strings:AppResources.TopCategories}" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Summary.TopCategories}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="reports:TopCategoryDto">
                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <Label Grid.Column="0" Text="{Binding CategoryName}" />
                            <Label Grid.Column="1" Text="{Binding Count, StringFormat='x{0}'}" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="{x:Static strings:AppResources.BusiestHours}" FontAttributes="Bold" />
            <CollectionView ItemsSource="{Binding Summary.BusiestHours}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="reports:HourCountDto">
                        <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                            <Label Grid.Column="0" Text="{Binding Hour, StringFormat='{0}:00'}" />
                            <Label Grid.Column="1" Text="{Binding Count, StringFormat={x:Static strings:AppResources.AppointmentCountFormat}}" FontSize="12" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
