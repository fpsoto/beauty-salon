<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Design tokens: "Professional Business Tool" identity - deep blue, neutral grays,
         no gradients/decorative color. Dark-mode values are derived (one shade lighter for
         accents, inverted neutrals for surfaces/text) since the brand brief only specified light. -->

    <!-- Brand primary -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryPressed">#1D4ED8</Color>
    <Color x:Key="PrimarySoft">#DBEAFE</Color>
    <Color x:Key="PrimaryDark">#3B82F6</Color>
    <Color x:Key="PrimaryPressedDark">#60A5FA</Color>
    <Color x:Key="PrimarySoftDark">#172554</Color>

    <!-- Surfaces -->
    <Color x:Key="Background">#FAFAFA</Color>
    <Color x:Key="BackgroundDark">#0F1115</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1A1D23</Color>
    <Color x:Key="Border">#E5E7EB</Color>
    <Color x:Key="BorderDark">#2D3139</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#111827</Color>
    <Color x:Key="TextPrimaryDark">#F3F4F6</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextSecondaryDark">#9CA3AF</Color>
    <Color x:Key="Placeholder">#9CA3AF</Color>
    <Color x:Key="PlaceholderDark">#6B7280</Color>

    <!-- Appointment status colors: accent (agenda card's left bar), container (badge
         background), and on-container (badge text) - each with its own light/dark pair
         instead of one flat value shared across themes. AppointmentStatusDisplay mirrors
         these as literal hex (see that class for why) - update both together. -->
    <Color x:Key="StatusBooked">#2563EB</Color>
    <Color x:Key="StatusBookedDark">#60A5FA</Color>
    <Color x:Key="StatusBookedContainer">#DBEAFE</Color>
    <Color x:Key="StatusBookedContainerDark">#172554</Color>
    <Color x:Key="StatusBookedOnContainer">#1E3A8A</Color>
    <Color x:Key="StatusBookedOnContainerDark">#BFDBFE</Color>

    <Color x:Key="StatusConfirmed">#047857</Color>
    <Color x:Key="StatusConfirmedDark">#34D399</Color>
    <Color x:Key="StatusConfirmedContainer">#D1FAE5</Color>
    <Color x:Key="StatusConfirmedContainerDark">#064E3B</Color>
    <Color x:Key="StatusConfirmedOnContainer">#065F46</Color>
    <Color x:Key="StatusConfirmedOnContainerDark">#A7F3D0</Color>

    <Color x:Key="StatusInProgress">#B45309</Color>
    <Color x:Key="StatusInProgressDark">#FBBF24</Color>
    <Color x:Key="StatusInProgressContainer">#FEF3C7</Color>
    <Color x:Key="StatusInProgressContainerDark">#78350F</Color>
    <Color x:Key="StatusInProgressOnContainer">#92400E</Color>
    <Color x:Key="StatusInProgressOnContainerDark">#FDE68A</Color>

    <Color x:Key="StatusCompleted">#475569</Color>
    <Color x:Key="StatusCompletedDark">#94A3B8</Color>
    <Color x:Key="StatusCompletedContainer">#E2E8F0</Color>
    <Color x:Key="StatusCompletedContainerDark">#334155</Color>
    <Color x:Key="StatusCompletedOnContainer">#334155</Color>
    <Color x:Key="StatusCompletedOnContainerDark">#E2E8F0</Color>

    <Color x:Key="StatusCancelled">#DC2626</Color>
    <Color x:Key="StatusCancelledDark">#F87171</Color>
    <Color x:Key="StatusCancelledContainer">#FEE2E2</Color>
    <Color x:Key="StatusCancelledContainerDark">#7F1D1D</Color>
    <Color x:Key="StatusCancelledOnContainer">#991B1B</Color>
    <Color x:Key="StatusCancelledOnContainerDark">#FECACA</Color>

    <Color x:Key="StatusNoShow">#7F1D1D</Color>
    <Color x:Key="StatusNoShowDark">#FDA4AF</Color>
    <Color x:Key="StatusNoShowContainer">#FECACA</Color>
    <Color x:Key="StatusNoShowContainerDark">#881337</Color>
    <Color x:Key="StatusNoShowOnContainer">#7F1D1D</Color>
    <Color x:Key="StatusNoShowOnContainerDark">#FECDD3</Color>

    <Color x:Key="StatusRescheduled">#7C3AED</Color>
    <Color x:Key="StatusRescheduledDark">#C4B5FD</Color>
    <Color x:Key="StatusRescheduledContainer">#EDE9FE</Color>
    <Color x:Key="StatusRescheduledContainerDark">#4C1D95</Color>
    <Color x:Key="StatusRescheduledOnContainer">#5B21B6</Color>
    <Color x:Key="StatusRescheduledOnContainerDark">#EDE9FE</Color>

    <Color x:Key="StatusBlock">#334155</Color>
    <Color x:Key="StatusBlockDark">#94A3B8</Color>
    <Color x:Key="StatusBlockContainer">#E2E8F0</Color>
    <Color x:Key="StatusBlockContainerDark">#334155</Color>
    <Color x:Key="StatusBlockOnContainer">#1E293B</Color>
    <Color x:Key="StatusBlockOnContainerDark">#E2E8F0</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#DC2626</Color>
    <Color x:Key="Info">#0EA5E9</Color>

    <!-- Legacy aliases kept so any leftover default-template reference (e.g. community
         toolkit control defaults) doesn't break; new work should use the tokens above. -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>
    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>
